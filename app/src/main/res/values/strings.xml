    <!-- Accessibility info card -->
    <string name="designed_for_accessibility">Designed for Accessibility</string>
    <string name="accessibility_info">This app is fully compatible with TalkBack screen reader. All buttons and controls have spoken descriptions.\n\nFeedback signals:\n• Too Low: Long slow vibrations + ascending tone + voice \"up\"\n• Too High: Quick short vibrations + descending tone + voice \"down\"\n• In Tune: Steady vibration + confirmation chime + voice \"in tune\"</string>

