    <!-- Slider settings titles and descriptions -->
    <string name="in_tune_threshold_title">In-Tune Threshold</string>
    <string name="in_tune_threshold_desc">How far from perfect pitch still counts as in tune. Default: ±10 cents.</string>
    <string name="pitch_smoothing_title">Pitch Smoothing</string>
    <string name="pitch_smoothing_desc">Averages multiple readings to reduce jitter. At ~22 readings/sec, 20 samples = ~0.9 sec averaging window. Default: 20 samples.</string>
    <string name="confidence_threshold_title">Confidence Threshold</string>
    <string name="confidence_threshold_desc">Minimum pitch detection confidence to accept a reading. Higher = more accurate but may miss quiet notes. Default: 90%.</string>
    <string name="state_stability_title">State Stability</string>
    <string name="state_stability_desc">Consecutive readings needed before changing the displayed state. At ~22 readings/sec, 10 readings = ~0.5 sec delay. Default: 10 readings.</string>

