<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for Android 12+ (API 31+)
    Excludes local_preferences (debug mode) from backup while allowing
    tuner_preferences (user settings) to be backed up.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude local preferences (debug mode) from backup -->
        <exclude domain="file" path="datastore/local_preferences.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <!-- Also exclude from device-to-device transfer -->
        <exclude domain="file" path="datastore/local_preferences.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
